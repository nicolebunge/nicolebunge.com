{
  "name": "nicolebunge.com",
  "description": "Personal website of Nicole Bunge",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check": "tsc",
    "coverage": "vitest run --coverage",
    "dev": "next dev",
    "format": "prettier --ignore-unknown --write .",
    "generate:svg": "npx @svgr/cli --icon --typescript --out-dir src/components/Icons src/images/icons",
    "generate": "npm-run-all --parallel generate:*",
    "lint:css": "stylelint --ignore-path .gitignore 'src/**/*.css'",
    "lint:js": "eslint",
    "lint": "npm-run-all --parallel lint:*",
    "start": "next start",
    "test": "vitest",
    "update": "npx npm-check-updates --format group --interactive"
  },
  "keywords": [
    "next"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicolebunge/nicolebunge.com"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "@types/mdx": "^2.0.14",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-use": "^17.6.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@storybook/react": "^10.5.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "happy-dom": "^20.11.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.5",
    "storybook": "^10.5.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
